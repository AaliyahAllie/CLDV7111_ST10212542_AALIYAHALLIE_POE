@model EventEaseT.Models.Booking

<div class="container mt-4">
    <h2>Edit Booking</h2>
    <form asp-action="EditBooking" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="BookingId" />

        <div class="mb-3">
            <label class="form-label">Your Name</label>
            <input asp-for="PersonName" class="form-control" />
            <span asp-validation-for="PersonName" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label class="form-label">Contact Details</label>
            <input asp-for="ContactDetails" class="form-control" />
            <span asp-validation-for="ContactDetails" class="text-danger"></span>
        </div>

        <button type="submit" class="btn btn-primary">Update Booking</button>
    </form>
</div>