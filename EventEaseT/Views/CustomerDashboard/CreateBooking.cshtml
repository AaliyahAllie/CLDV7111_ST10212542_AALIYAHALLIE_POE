@model EventEaseT.Models.Booking

<div class="container mt-4">
    <h2>Book an Event</h2>
    <form asp-action="CreateBooking" method="post">
        @Html.AntiForgeryToken()

        <div class="mb-3">
            <label class="form-label">Event</label>
            <select asp-for="EventId"
                    asp-items="@(new SelectList(ViewBag.Events, "EventId", "EventName"))"
                    class="form-control"></select>
            <span asp-validation-for="EventId" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label class="form-label">Venue</label>
            <select asp-for="VenueId"
                    asp-items="@(new SelectList(ViewBag.Venues, "VenueId", "VenueName"))"
                    class="form-control"></select>
            <span asp-validation-for="VenueId" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label class="form-label">Your Name</label>
            <input asp-for="PersonName" class="form-control" />
            <span asp-validation-for="PersonName" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label class="form-label">Contact Details</label>
            <input asp-for="ContactDetails" class="form-control" />
            <span asp-validation-for="ContactDetails" class="text-danger"></span>
        </div>

        <!-- NEW: Booking Date -->
        <div class="mb-3">
            <label class="form-label">Booking Date</label>
            <input asp-for="BookingDate" type="date" class="form-control" />
            <span asp-validation-for="BookingDate" class="text-danger"></span>
        </div>

        <button type="submit" class="btn btn-success">Save Booking</button>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}

