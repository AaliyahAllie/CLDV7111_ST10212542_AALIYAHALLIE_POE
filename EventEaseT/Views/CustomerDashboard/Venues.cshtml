@model IEnumerable<EventEaseT.Models.Venue>

<div class="container mt-4">
    <h2>Available Venues</h2>

    <div class="row">
        @foreach (var venue in Model)
        {
            <div class="col-md-4 mb-4">
                <div class="card h-100 shadow-sm">
                    <!-- Venue image -->
                    <img src="@venue.ImageUrl" class="card-img-top venue-img" alt="@venue.VenueName" />

                    <div class="card-body">
                        <h5 class="card-title">@venue.VenueName</h5>
                        <p class="card-text">
                            <strong>Location:</strong> @venue.Location <br />
                            <strong>Capacity:</strong> @venue.Capacity
                        </p>
                    </div>

                    <div class="card-footer text-center">
                        <a asp-controller="CustomerDashboard"
                           asp-action="CreateBooking"
                           asp-route-venueId="@venue.VenueId"
                           class="btn btn-primary">
                            Book This Venue
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
</div>